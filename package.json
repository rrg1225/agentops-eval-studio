{
  "name": "agentops-eval-studio",
  "version": "1.0.0",
  "description": "Agent engineering studio with deterministic tool orchestration, policy guardrails, trace replay, and scenario evaluations.",
  "type": "module",
  "license": "MIT",
  "author": "lixian",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "test": "node --test test/*.test.js && npm run eval",
    "eval": "node eval/scenarios.test.js",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "keywords": [
    "ai-agent",
    "agent-engineering",
    "tool-calling",
    "guardrails",
    "evaluation",
    "trace-replay",
    "react",
    "express"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.4.2"
  },
  "devDependencies": {}
}
